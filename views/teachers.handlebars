{{#if showTeachers}}
<div class="card">
    <div class="card-header">
        <div class="header-content">
            <div class="header-title">
                <i class="fas fa-chalkboard-teacher"></i>
                <h3>{{title}}</h3>
            </div>
            <div class="header-actions">
                <a href="/manage-teachers" class="btn btn-success btn-responsive">
                    <i class="fas fa-plus"></i> 
                    <span class="btn-text">Add Teacher</span>
                </a>
            </div>
        </div>
    </div>
    
    {{#if error}}
    <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i> {{error}}
    </div>
    {{/if}}
    
    {{#if teachers.length}}
        <div class="table-responsive">
            <div class="teachers-table">
                <table>
                    <thead>
                        <tr>
                            <th><i class="fas fa-user"></i> Name</th>
                            <th><i class="fas fa-book"></i> Subject</th>
                            <th><i class="fas fa-building"></i> Department</th>
                            <th class="hide-mobile"><i class="fas fa-birthday-cake"></i> Age</th>
                            <th class="hide-mobile"><i class="fas fa-clock"></i> Experience</th>
                            <th class="hide-mobile"><i class="fas fa-dollar-sign"></i> Salary</th>
                            <th class="hide-tablet"><i class="fas fa-envelope"></i> Email</th>
                            <th class="hide-tablet"><i class="fas fa-phone"></i> Phone</th>
                            <th class="actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each teachers}}
                        <tr>
                            <td data-label="Name">
                                <div class="teacher-info">
                                    <strong>{{this.name}}</strong>
                                    <div class="mobile-details">
                                        <small>{{this.age}} years • {{this.experience}} years exp.</small>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Subject">{{this.subject}}</td>
                            <td data-label="Department">{{this.department}}</td>
                            <td data-label="Age" class="hide-mobile">{{this.age}}</td>
                            <td data-label="Experience" class="hide-mobile">{{this.experience}} years</td>
                            <td data-label="Salary" class="hide-mobile">৳{{this.salary}}</td>
                            <td data-label="Email" class="hide-tablet">
                                <a href="mailto:{{this.email}}">{{this.email}}</a>
                            </td>
                            <td data-label="Phone" class="hide-tablet">
                                <a href="tel:{{this.phone}}">{{this.phone}}</a>
                            </td>
                            <td data-label="Actions" class="actions-column">
                                <div class="action-buttons">
                                    <a href="/manage-teachers" class="btn btn-small btn-edit">
                                        <i class="fas fa-edit"></i>
                                        <span class="btn-text">Edit</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="card-footer">
            <div class="footer-actions">
                <a href="/manage-teachers" class="btn btn-warning">
                    <i class="fas fa-cogs"></i> 
                    <span class="btn-text">Manage All Teachers</span>
                </a>
            </div>
        </div>
    {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h3>No teachers found</h3>
            <p>Start by adding some teachers to the system.</p>
            <div class="empty-actions">
                <a href="/manage-teachers" class="btn btn-success btn-large">
                    <i class="fas fa-plus"></i> Add Your First Teacher
                </a>
            </div>
        </div>
    {{/if}}
    
    <div class="navigation-footer">
        <a href="/" class="btn btn-secondary">
            <i class="fas fa-home"></i> 
            <span class="btn-text">Back to Dashboard</span>
        </a>
    </div>
</div>

<style>
/* Responsive Table Styles */
.table-responsive {
    overflow-x: auto;
    margin: 0 -1rem;
    padding: 0 1rem;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}

.header-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.header-actions {
    display: flex;
    gap: 0.5rem;
}

.teacher-info .mobile-details {
    display: none;
    color: #666;
    font-size: 0.85em;
    margin-top: 0.25rem;
}

.actions-column {
    width: 120px;
    text-align: center;
}

.action-buttons {
    display: flex;
    gap: 0.25rem;
    justify-content: center;
}

.card-footer, .navigation-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e0e0e0;
    text-align: center;
}

.footer-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.empty-state {
    text-align: center;
    padding: 3rem 1rem;
}

.empty-icon {
    font-size: 4rem;
    color: #ccc;
    margin-bottom: 1rem;
}

.empty-actions {
    margin-top: 2rem;
}

.btn-responsive {
    white-space: nowrap;
}

/* Mobile Styles */
@media (max-width: 768px) {
    .hide-mobile {
        display: none !important;
    }
    
    .teacher-info .mobile-details {
        display: block;
    }
    
    .header-content {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
    }
    
    .header-actions {
        justify-content: center;
    }
    
    .teachers-table table {
        font-size: 0.9em;
    }
    
    .btn .btn-text {
        display: none;
    }
    
    .btn-large .btn-text {
        display: inline;
    }
    
    .footer-actions {
        flex-direction: column;
        align-items: center;
    }
    
    .action-buttons {
        flex-direction: column;
    }
}

/* Tablet Styles */
@media (max-width: 1024px) {
    .hide-tablet {
        display: none !important;
    }
}

/* Large Mobile Styles */
@media (max-width: 480px) {
    .card {
        margin: 0.5rem;
    }
    
    .table-responsive {
        margin: 0 -0.5rem;
        padding: 0 0.5rem;
    }
    
    .teachers-table table {
        font-size: 0.8em;
    }
    
    .btn {
        padding: 0.5rem;
        font-size: 0.9em;
    }
    
    .header-title h3 {
        font-size: 1.2em;
    }
}

/* Enhanced Button Styles */
.btn-small {
    padding: 0.25rem 0.5rem;
    font-size: 0.8em;
}

.btn-large {
    padding: 0.75rem 1.5rem;
    font-size: 1.1em;
}

.btn-edit {
    background-color: #007bff;
    color: white;
}

.btn-edit:hover {
    background-color: #0056b3;
}
</style>
{{/if}}